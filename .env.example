# =============================================================================
# Rols Storefront EU — local development environment template
# =============================================================================
#
# Copy this file to `.env` (which is gitignored) and fill the values.
#
# Two ways to populate the Shopify-issued tokens:
#
#  1. AUTOMATIC (recommended): pull them from the Hydrogen channel via CLI:
#       npx shopify hydrogen link
#       npx shopify hydrogen env pull
#     This requires the Shopify CLI logged in to your store. The link command
#     associates this local repo with the `Rols Carpets EU Hydrogen` storefront,
#     and `env pull` writes the tokens into your local `.env`.
#
#  2. MANUAL: copy each value from the Hydrogen channel admin UI:
#       Shopify admin → Hydrogen → Rols Carpets EU Hydrogen → Storefront settings
#     The token names in the admin map 1:1 to the variable names below.
#
# In Oxygen production deploys these variables are injected automatically by
# Shopify when the storefront is linked, so the production site does not depend
# on what's in this file. This file only affects `npm run dev` locally.
# =============================================================================

# ---- Shopify Storefront API ----
PUBLIC_STORE_DOMAIN="rols-europe.myshopify.com"
PUBLIC_STOREFRONT_API_TOKEN=""
PRIVATE_STOREFRONT_API_TOKEN=""
PUBLIC_STOREFRONT_ID=""
PUBLIC_STOREFRONT_API_VERSION="2026-01"

# ---- Customer Account API (login, account pages) ----
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# ---- Checkout ----
PUBLIC_CHECKOUT_DOMAIN="rols-europe.myshopify.com"

# ---- Session encryption ----
# Generate locally with: openssl rand -base64 32
# Production secret is injected by Oxygen — do not commit a real one.
SESSION_SECRET="change-me-locally-only"
